-- ================= AUTO CLICKER (ADDED) =================
getgenv().AutoClicker = false
local clicking = false

local function StartAutoClicker()
	if clicking then return end
	clicking = true

	task.spawn(function()
		while getgenv().AutoClicker do
			task.wait(0.05)
			mouse1click()
		end
		clicking = false
	end)
end

local autoClickBtn = btn(card(pageMain,45),"Auto Clicker : OFF")
autoClickBtn.MouseButton1Click:Connect(function()
	getgenv().AutoClicker = not getgenv().AutoClicker
	
	if getgenv().AutoClicker then
		StartAutoClicker()
	end
	
	autoClickBtn.Text = "Auto Clicker : "..(getgenv().AutoClicker and "ON" or "OFF")
end)

